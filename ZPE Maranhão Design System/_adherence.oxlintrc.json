{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/cards/**",
              "components/core/**",
              "components/forms/**",
              "components/motifs/**",
              "components/surfaces/**",
              "ui_kits/site-institucional/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Barlow|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Barlow, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArrowImage'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|size|tone|tint|key|ref|className|style|children)$/]",
        "message": "<ArrowImage> doesn't accept that prop. Declared props: src, size, tone, tint."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArrowImage'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|blue-bright|green)$/]",
        "message": "<ArrowImage> tone must be one of 'blue' | 'blue-bright' | 'green'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandArrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|mode|color|opacity|key|ref|className|style|children)$/]",
        "message": "<BrandArrow> doesn't accept that prop. Declared props: size, mode, color, opacity."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandArrow'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:solid|outline)$/]",
        "message": "<BrandArrow> mode must be one of 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|iconRight|iconLeft|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, iconRight, iconLeft, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|children|interactive|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: eyebrow, title, children, interactive."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|blue|muted|light)$/]",
        "message": "<Eyebrow> tone must be one of 'green' | 'blue' | 'muted' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|title|children|accent|key|ref|className|style|children)$/]",
        "message": "<GlassPanel> doesn't accept that prop. Declared props: number, title, children, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:theme|basePath|size|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: theme, basePath, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<Logo> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RippleField'] > JSXAttribute > JSXIdentifier[name!=/^(?:origin|count|gap|radius|color|strokeWidth|opacity|key|ref|className|style|children)$/]",
        "message": "<RippleField> doesn't accept that prop. Declared props: origin, count, gap, radius, color, strokeWidth, opacity."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|label|detail|tone|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: value, unit, label, detail, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|green)$/]",
        "message": "<StatCard> tone must be one of 'blue' | 'green'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
